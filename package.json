{
  "name": "roybal-restoration-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/mobile",
    "apps/web",
    "apps/field",
    "apps/board",
    "packages/shared"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=apps/mobile",
    "web": "npm run dev --workspace=apps/web",
    "field": "npm run dev --workspace=apps/field",
    "field:test": "npm run test --workspace=apps/field",
    "board": "npm run dev --workspace=apps/board",
    "shared:build": "npm run build --workspace=packages/shared",
    "setup": "npm install && npm run shared:build"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
